<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Memory Match 🧠</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0c29;
    --card-back: #302b63;
    --card-front: #24243e;
    --accent: #f7971e;
    --accent2: #ffd200;
    --match: #43e97b;
    --text: #fff;
    --shadow: 0 8px 32px rgba(247,151,30,0.18);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    min-height: 100vh;
    background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
    font-family: 'Nunito', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 24px 16px 40px;
    overflow-x: hidden;
  }

  /* Floating stars bg */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px),
      radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 60px 60px, 30px 30px;
    background-position: 0 0, 15px 15px;
    pointer-events: none;
    z-index: 0;
  }

  .container { position: relative; z-index: 1; width: 100%; max-width: 520px; }

  header { text-align: center; margin-bottom: 24px; }

  h1 {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(2rem, 6vw, 3rem);
    background: linear-gradient(90deg, #f7971e, #ffd200);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 1px;
    filter: drop-shadow(0 2px 12px rgba(247,151,30,0.4));
  }

  .tagline {
    color: rgba(255,255,255,0.5);
    font-size: 0.9rem;
    margin-top: 4px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* Stats bar */
  .stats {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .stat-box {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(247,151,30,0.2);
    border-radius: 16px;
    padding: 10px 20px;
    text-align: center;
    backdrop-filter: blur(8px);
    min-width: 90px;
  }

  .stat-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
    font-weight: 800;
  }

  .stat-value {
    font-family: 'Fredoka One', cursive;
    font-size: 1.6rem;
    color: var(--accent2);
    line-height: 1.1;
  }

  /* Grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 24px;
  }

  /* Card */
  .card {
    aspect-ratio: 1;
    perspective: 600px;
    cursor: pointer;
  }

  .card-inner {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 16px;
  }

  .card.flipped .card-inner { transform: rotateY(180deg); }
  .card.matched .card-inner { transform: rotateY(180deg); }

  .card-back, .card-front {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    backface-visibility: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-back {
    background: linear-gradient(135deg, #302b63, #24243e);
    border: 2px solid rgba(247,151,30,0.25);
    font-size: 1.6rem;
    color: rgba(247,151,30,0.4);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .card:hover:not(.flipped):not(.matched) .card-back {
    border-color: rgba(247,151,30,0.7);
    box-shadow: 0 4px 24px rgba(247,151,30,0.25);
  }

  .card-front {
    background: linear-gradient(135deg, #24243e, #302b63);
    border: 2px solid rgba(255,255,255,0.08);
    transform: rotateY(180deg);
    font-size: clamp(1.6rem, 5vw, 2.2rem);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
  }

  .card.matched .card-front {
    background: linear-gradient(135deg, #1a4a2e, #1e5c38);
    border-color: rgba(67,233,123,0.5);
    box-shadow: 0 0 20px rgba(67,233,123,0.3);
    animation: matchPulse 0.5s ease;
  }

  @keyframes matchPulse {
    0%   { transform: rotateY(180deg) scale(1); }
    50%  { transform: rotateY(180deg) scale(1.12); }
    100% { transform: rotateY(180deg) scale(1); }
  }

  .card.wrong .card-inner {
    animation: shake 0.4s ease;
  }

  @keyframes shake {
    0%,100% { transform: rotateY(180deg) translateX(0); }
    20%      { transform: rotateY(180deg) translateX(-6px); }
    40%      { transform: rotateY(180deg) translateX(6px); }
    60%      { transform: rotateY(180deg) translateX(-4px); }
    80%      { transform: rotateY(180deg) translateX(4px); }
  }

  /* Buttons */
  .btn {
    font-family: 'Fredoka One', cursive;
    font-size: 1.1rem;
    padding: 12px 32px;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    letter-spacing: 1px;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .btn:active { transform: scale(0.95); }

  .btn-primary {
    background: linear-gradient(90deg, #f7971e, #ffd200);
    color: #1a1a2e;
    box-shadow: 0 4px 20px rgba(247,151,30,0.4);
  }

  .btn-primary:hover { box-shadow: 0 6px 28px rgba(247,151,30,0.6); transform: translateY(-2px); }

  .controls { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }

  /* Difficulty */
  .diff-row {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .diff-btn {
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    font-size: 0.78rem;
    padding: 6px 16px;
    border-radius: 50px;
    border: 2px solid rgba(255,255,255,0.15);
    background: transparent;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.2s;
  }

  .diff-btn.active, .diff-btn:hover {
    border-color: var(--accent);
    color: var(--accent2);
    background: rgba(247,151,30,0.1);
  }

  /* Win overlay */
  .win-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15,12,41,0.92);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 100;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s;
    backdrop-filter: blur(6px);
  }

  .win-overlay.show { opacity: 1; pointer-events: all; }

  .win-box {
    background: linear-gradient(135deg, #302b63, #24243e);
    border: 2px solid rgba(247,151,30,0.4);
    border-radius: 28px;
    padding: 40px 48px;
    text-align: center;
    box-shadow: 0 20px 60px rgba(247,151,30,0.2);
    animation: popIn 0.4s cubic-bezier(0.34,1.56,0.64,1);
  }

  @keyframes popIn {
    from { transform: scale(0.5); opacity: 0; }
    to   { transform: scale(1); opacity: 1; }
  }

  .win-emoji { font-size: 3.5rem; margin-bottom: 8px; }

  .win-title {
    font-family: 'Fredoka One', cursive;
    font-size: 2.2rem;
    background: linear-gradient(90deg, #f7971e, #ffd200);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
  }

  .win-score {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    margin-bottom: 24px;
    font-weight: 600;
  }

  .confetti-piece {
    position: fixed;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    pointer-events: none;
    z-index: 200;
    animation: fall linear forwards;
  }

  @keyframes fall {
    0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }
</style>
</head>
<body>

<div class="container">
  <header>
    <h1>🧠 Memory Match</h1>
    <p class="tagline">Cards flip karo — pairs dhundo!</p>
  </header>

  <div class="stats">
    <div class="stat-box">
      <div class="stat-label">Moves</div>
      <div class="stat-value" id="moves">0</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">Pairs</div>
      <div class="stat-value" id="pairs">0 / 8</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">Time</div>
      <div class="stat-value" id="timer">0s</div>
    </div>
  </div>

  <div class="diff-row">
    <button class="diff-btn active" onclick="setDiff(4,4,'Easy')">Easy (4×4)</button>
    <button class="diff-btn" onclick="setDiff(4,5,'Medium')">Medium (4×5)</button>
    <button class="diff-btn" onclick="setDiff(5,6,'Hard')">Hard (5×6)</button>
  </div>

  <div class="grid" id="grid"></div>

  <div class="controls">
    <button class="btn btn-primary" onclick="startGame()">🔄 New Game</button>
  </div>
</div>

<!-- Win overlay -->
<div class="win-overlay" id="winOverlay">
  <div class="win-box">
    <div class="win-emoji">🏆</div>
    <div class="win-title">Shabash!</div>
    <div class="win-score" id="winScore"></div>
    <button class="btn btn-primary" onclick="closeWin()">▶ Phir Khelo</button>
  </div>
</div>

<script>
  const EMOJI_POOL = ['🦊','🐬','🦋','🌸','🍕','🎸','🚀','🌈','🦁','🐙','🍓','🎯','🦄','🏄','🌴','🎲','🔥','⚡','🦅','🐉','🍦','🎪','🌙','🍄'];

  let cols = 4, rows = 4, totalPairs = 8;
  let flipped = [], matched = [], moves = 0, gameActive = false;
  let timerInterval, seconds = 0, lockBoard = false;

  function setDiff(c, r, label) {
    cols = c; rows = r; totalPairs = (c * r) / 2;
    document.querySelectorAll('.diff-btn').forEach(b => b.classList.toggle('active', b.textContent.startsWith(label)));
    startGame();
  }

  function startGame() {
    clearInterval(timerInterval);
    seconds = 0; moves = 0; matched = []; flipped = []; lockBoard = false; gameActive = false;
    updateStats();
    document.getElementById('grid').style.gridTemplateColumns = `repeat(${cols}, 1fr)`;

    const emojis = [...EMOJI_POOL].sort(() => Math.random() - 0.5).slice(0, totalPairs);
    const deck = [...emojis, ...emojis].sort(() => Math.random() - 0.5);

    const grid = document.getElementById('grid');
    grid.innerHTML = '';
    deck.forEach((emoji, i) => {
      const card = document.createElement('div');
      card.className = 'card';
      card.dataset.emoji = emoji;
      card.dataset.index = i;
      card.innerHTML = `
        <div class="card-inner">
          <div class="card-back">✦</div>
          <div class="card-front">${emoji}</div>
        </div>`;
      card.addEventListener('click', () => flipCard(card));
      grid.appendChild(card);

      // stagger entrance
      card.style.opacity = '0';
      card.style.transform = 'scale(0.5)';
      card.style.transition = 'opacity 0.3s, transform 0.3s';
      setTimeout(() => { card.style.opacity = '1'; card.style.transform = 'scale(1)'; }, i * 40);
    });

    setTimeout(() => {
      gameActive = true;
      timerInterval = setInterval(() => {
        seconds++;
        document.getElementById('timer').textContent = seconds + 's';
      }, 1000);
    }, deck.length * 40 + 200);
  }

  function flipCard(card) {
    if (!gameActive || lockBoard) return;
    if (card.classList.contains('flipped') || card.classList.contains('matched')) return;
    if (flipped.length >= 2) return;

    card.classList.add('flipped');
    flipped.push(card);

    if (flipped.length === 2) {
      moves++;
      updateStats();
      lockBoard = true;

      const [a, b] = flipped;
      if (a.dataset.emoji === b.dataset.emoji) {
        // Match!
        setTimeout(() => {
          a.classList.add('matched'); b.classList.add('matched');
          a.classList.remove('flipped'); b.classList.remove('flipped');
          matched.push(a, b);
          flipped = [];
          lockBoard = false;
          updateStats();
          if (matched.length === cols * rows) winGame();
        }, 400);
      } else {
        // No match
        a.classList.add('wrong'); b.classList.add('wrong');
        setTimeout(() => {
          a.classList.remove('flipped','wrong');
          b.classList.remove('flipped','wrong');
          flipped = [];
          lockBoard = false;
        }, 900);
      }
    }
  }

  function updateStats() {
    document.getElementById('moves').textContent = moves;
    document.getElementById('pairs').textContent = `${matched.length/2} / ${totalPairs}`;
  }

  function winGame() {
    clearInterval(timerInterval);
    gameActive = false;
    launchConfetti();
    document.getElementById('winScore').textContent =
      `${moves} moves mein ${seconds} seconds mein complete kiya! 🎉`;
    setTimeout(() => document.getElementById('winOverlay').classList.add('show'), 300);
  }

  function closeWin() {
    document.getElementById('winOverlay').classList.remove('show');
    startGame();
  }

  function launchConfetti() {
    const colors = ['#f7971e','#ffd200','#43e97b','#fa709a','#a18cd1','#fccb90'];
    for (let i = 0; i < 80; i++) {
      const el = document.createElement('div');
      el.className = 'confetti-piece';
      el.style.cssText = `
        left: ${Math.random()*100}vw;
        top: -10px;
        background: ${colors[Math.floor(Math.random()*colors.length)]};
        width: ${6+Math.random()*8}px;
        height: ${6+Math.random()*8}px;
        animation-duration: ${1.5+Math.random()*2}s;
        animation-delay: ${Math.random()*0.8}s;
        border-radius: ${Math.random()>0.5?'50%':'3px'};
      `;
      document.body.appendChild(el);
      el.addEventListener('animationend', () => el.remove());
    }
  }

  // Start on load
  startGame();
</script>
</body>
</html>
